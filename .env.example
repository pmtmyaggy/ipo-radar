# IPO-Radar 环境变量配置

# EDGAR API
EDGAR_IDENTITY=YourName your@email.com

# 飞书Webhook (可选)
FEISHU_WEBHOOK_URL=

# OpenAI API (可选，用于情绪分析)
# 支持 OpenAI 官方及所有兼容平台 (阿里云百炼、智谱 AI、DeepSeek 等)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# 注意: 某些平台如 linkapi 需要加 /v1 路径
OPENAI_MODEL=gpt-4o-mini

# 数据库
DATABASE_URL=sqlite:///data/ipo_radar.db

# 日志级别
LOG_LEVEL=INFO
